            [div id="section-idle-xp" style="
            margin:10px auto; 
            background-color:rgba(254, 254, 254, 0.1); 
            padding:10px; 
            border-radius:10px; 
            border:2px ridge rgba(255, 255, 255, 0.5); 
            box-shadow: inset 0 0 20px rgba(0, 0, 0, 1), 0 0 20px rgba(0, 0, 0, 0.5);  
            color:#E0E0E0; 
            font-size:14px;
            text-align:left;"]
                [div align="center" style="text-align:center; font-size:25px; margin-bottom:15px;"][color=#cea425]IDLE XP[/color]
                    [url=#section-idle-sets style="font-size:14px;"][color=#2980B9]▲ Back to top ▲[/color][/url]
                [/div]
                [table width="100%"]
                    [tr]
                        [td style="color:#E0E0E0; line-height:2; font-size:14px; padding:10px;"]For this [color=#F7D58B]Idle XP set at Crawler's Nest [S][/color], it is a [color=#F7D58B]classic Idle PDT set[/color] optimized with the [color=#66ccff]full Chevalier's set[/color] [size=12][i]"In this area, the body armor bug against Fomors does not occur"[/i][/size], allowing it to be used safely and fully benefit from the set bonus [size=12][i]"Occasionally Absorbs Damage Taken"[/i][/size], providing a [color=#7fe07f]5% chance to recover HP[/color].

                            With over 100 enemies engaged during the pull and since the player is often facing away, the proc activates regularly, offering effective passive regeneration during the gathering phases.
                        [/td]
                    [/tr]
                [/table]
                [div align="center"]
                    [table style="border-collapse:collapse; padding:5px; line-height:1.8; box-shadow:0 0 2px rgba(255, 223, 128, 1), 0 0 4px rgba(255, 223, 128, 1), 0 0 12px rgba(255, 223, 128, 1); border-radius:25px; overflow:hidden;"]
                        [tr style="background-color:rgba(0, 0, 0, 0.3);"]
                            [td style="text-align:center; padding:10px; vertical-align:middle; width:130px;"]
                                [itemset]397864[/itemset]
                            [/td]
                            [td style="color:#ffffff; text-align:center; padding:10px; vertical-align:middle; white-space:nowrap;"][div style="text-align:left; display:inline-block; line-height:1.5;"][size=14]• [b][color=#F7D58B]PDT II: -68%[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]MDT II: -65%[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]Enmity: +74[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]CE Loss Reduction: 73%[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]Ailment resistance: 21%[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]VIT: +325[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]DEF: +1500[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]HP: +844[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]Magic Evasion: +667[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]Magic Def. Bonus: +35[/color][/b][/size]
                                [/div]
                            [/td]
                        [/tr]
                    [/table]
                [/div]
            [/div]

            [div id="section-idle-town" style="
            margin:10px auto; 
            background-color:rgba(254, 254, 254, 0.1); 
            padding:10px; 
            border-radius:10px; 
            border:2px ridge rgba(255, 255, 255, 0.5); 
            box-shadow: inset 0 0 20px rgba(0, 0, 0, 1), 0 0 20px rgba(0, 0, 0, 0.5);  
            color:#E0E0E0; 
            font-size:14px;
            text-align:left;"]
                [div align="center" style="text-align:center; font-size:25px; margin-bottom:15px;"][color=#cea425]IDLE REFRESH / TOWN[/color]
                    [url=#section-idle-sets style="font-size:14px;"][color=#2980B9]▲ Back to top ▲[/color][/url]
                [/div]
                [table width="100%"]
                    [tr]
                        [td style="color:#E0E0E0; line-height:2; font-size:14px; padding:10px;"]For the [b][color=#F7D58B]Idle Refresh / Town set[/color][/b], this setup is designed specifically for resting in safe zones or town areas where there is no danger. It focuses on maximizing [b]MP and HP regeneration[/b] while maintaining a balanced pool of both. The use of [color=#66ccff]Carmine Cuisses +1[/color] in the leg slot is purely for the [color=#F7D58B][b]+18% movement speed[/b][/color] boost, allowing faster movement around town. This configuration ensures efficient recovery and quick mobility during downtime.
                        [/td]
                    [/tr]
                [/table]
                [div align="center"]
                    [table style="border-collapse:collapse; padding:5px; line-height:1.8; box-shadow:0 0 2px rgba(255, 223, 128, 1), 0 0 4px rgba(255, 223, 128, 1), 0 0 12px rgba(255, 223, 128, 1); border-radius:25px; overflow:hidden;"]
                        [tr style="background-color:rgba(0, 0, 0, 0.3);"]
                            [td style="text-align:center; padding:10px; vertical-align:middle; width:130px;"]
                                [itemset]397548[/itemset]
                            [/td]
                            [td style="color:#ffffff; text-align:center; padding:10px; vertical-align:middle; white-space:nowrap;"][div style="text-align:left; display:inline-block; line-height:1.5;"][size=14]• [b][color=#F7D58B]Refresh: +6[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]Regen: +1[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]Movement Speed: +18%[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]HP: +986[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]MP: +311[/color][/b][/size]
                                [/div]
                            [/td]
                        [/tr]
                    [/table]
                [/div]
            [/div]
        [/div]

        [div style="margin:25px auto; background-color:rgba(26, 26, 26, 0.85); width:100%; padding:5px; border-radius:15px; border:2px ridge rgba(255, 223, 128, 1); box-shadow:0 0 10px rgba(244, 228, 142, 0.8), 0 0 5px rgba(255, 223, 0, 0.6) inset;"][div align="center" style="margin:15px 0 25px 0; padding:10px;"][img style="width:450px; height:auto;"]https://i.imgur.com/Rd4V1im.png[/img][/div]
            [div style="font-size:26px; font-weight:bold; color:#ffd700; text-shadow: 0px 0px 5px rgba(253, 108, 0, 0.5), 0px 0px 10px rgba(253, 108, 0, 0.5), 0px 0px 15px rgba(253, 108, 0, 0.5);"]ENMITY SETS[/div]
                [url=#section-enmity-sets style="font-size:14px;"][color=#2980B9]▲ Back to top ▲[/color][/url]
            
            [div style="
            margin:10px auto; 
            background-color:rgba(254, 254, 254, 0.1); 
            padding:10px; 
            border-radius:10px; 
            border:2px ridge rgba(255, 255, 255, 0.5); 
            box-shadow: inset 0 0 20px rgba(0, 0, 0, 1), 0 0 20px rgba(0, 0, 0, 0.5);  
            color:#E0E0E0; 
            font-size:14px;
            line-height:1.5;
            text-align:left;"][div align="center" style="text-align:center; font-size:25px; margin-bottom:15px;"][color=#cea425]Enmity Set Overview[/color][/div]

                The [color=#F7D58B][b]Enmity Set[/b][/color] is designed to maximize threat generation and maintain enemy focus. 
                This setup prioritizes [color=#ff7f50]Enmity+[/color] gear to ensure consistent hate retention, allowing for full control over aggressive targets. 
                Key elements include stacking [color=#F7D58B]VIT[/color], [color=#F7D58B]HP[/color], and maintaining capped [color=#F7D58B]PDT[/color] and [color=#F7D58B]MDT[/color] 
                to reduce incoming damage while generating maximum enmity.

                [color=#cea425][b]Conclusion[/b][/color]
                The Enmity Set is essential for holding aggro by maximizing threat generation while ensuring damage mitigation 
                through capped defenses and solid defensive stats.
            [/div]

            [div id="section-full-enmity" style="
            margin:10px auto; 
            background-color:rgba(254, 254, 254, 0.1); 
            padding:10px; 
            border-radius:10px; 
            border:2px ridge rgba(255, 255, 255, 0.5); 
            box-shadow: inset 0 0 20px rgba(0, 0, 0, 1), 0 0 20px rgba(0, 0, 0, 0.5);  
            color:#E0E0E0; 
            font-size:14px;
            text-align:left;"]
                [div align="center" style="text-align:center; font-size:25px; margin-bottom:15px;"][color=#cea425]Full Enmity Set
                    [url=#section-enmity-sets style="font-size:14px;"][color=#2980B9]▲ Back to top ▲[/color][/url][/div][table]
                    [tr][td style="color:#E0E0E0; line-height:2; font-size:14px; padding:10px;"]The [color=#66ccff]Full Enmity Set[/color] is intended for shorter, rapid spells or [color=#e5d522]Job Abilities (JAs)[/color] (e.g. [color=#00ffd0]Flash[/color], [color=#00ffd0]Jettatura[/color]) with a low chance of interruption. It maximizes [color=#ff7f50]Enmity[/color] while maintaining a [color=#7fe07f]~3000 HP pool[/color] and staying sufficiently tanky.

                            • [color=#F7D58B]PDT & MDT[/color]: Ideally, aim to cap both physical and magical damage reduction.  
                            • [color=#7fe07f]~3000 HP Pool[/color]: Ensures a healthy HP total for survivability.  
                            • [color=#ff7f50]Maximize Enmity[/color]: Focus on boosting threat without sacrificing the above stats.

                            By focusing on [color=#ff7f50]Enmity[/color] for quick, essential abilities and fast-casting spells while preserving robust defense and HP this set achieves high threat generation without compromising durability.
                        [/td]
                    [/tr]
                [/table][div align="center"][table style="border-collapse:collapse; padding:5px; margin-top:15px; margin-bottom:15px; line-height:1.8; box-shadow:0 0 2px rgba(255, 223, 128, 1), 0 0 4px rgba(255, 223, 128, 1), 0 0 12px rgba(255, 223, 128, 1); border-radius:25px; overflow:hidden;"]
                        [tr style="background-color:rgba(0, 0, 0, 0.3);"][td style="text-align:center; padding:10px; vertical-align:middle; width:130px;"][itemset]397521[/itemset][/td]
                            [td style="color:#ffffff; text-align:center; padding:10px; vertical-align:middle; white-space:nowrap;"][div style="text-align:left; display:inline-block; line-height:1.5;"][size=14]• [b][color=#F7D58B]PDT: -62%[/color][/b][/size]
                                    [size=14]• [color=#F7D58B][b]MDT: -54%[/b][/color][/size] [size=12][color=#F7D58B][i](Capped with Shell)[/i][/color][/size]
                                    [size=14]• [b][color=#F7D58B]Enmity: +159[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]VIT: +205[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]DEF: +1140[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]HP: +809[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]MP: +263[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]Magic Evasion: +409[/color][/b][/size]
                                    [size=14]• [b][color=#F7D58B]Magic Def. Bonus: +18%[/color][/b][/size]
                                [/div]
                            [/td]
                            [td style="color:#ffffff; text-align:center; padding:10px; vertical-align:top; white-space:nowrap;"][size=12][b][color=#66ccff]Rudianos's Mantle Augments[/color][/b][/size][size=12]
                                    • [b][color=#F7D58B]VIT: +20[/color][/b][/size]
                                    [size=12]• [b][color=#F7D58B]PDT: -10%[/color][/b][/size]
                                    [size=12]• [b][color=#F7D58B]Mag Eva: +10[/color][/b][/size]
                                    [size=12]• [b][color=#F7D58B]Eva. / Mag Eva: +20[/color][/b][/size]
                                    [size=12]• [b][color=#F7D58B]Enmity: +10[/color][/b][/size]
                            [/td]
                        [/tr]
                    [/table]
