                        [th style="color:#ffd700; text-align:center; padding:10px; border-bottom:1px ridge rgba(255, 255, 255, 0.2); border-right:1px ridge rgba(255, 255, 255, 0.2);"]Equipment Bonus[/th]
                        [th style="color:#ffd700; text-align:center; padding:10px; border-bottom:1px ridge rgba(255, 255, 255, 0.2); border-right:1px ridge rgba(255, 255, 255, 0.2);"]Crusade Bonus[/th]
                        [th style="color:#ffd700; text-align:center; padding:10px; border-bottom:1px ridge rgba(255, 255, 255, 0.2); border-right:1px ridge rgba(255, 255, 255, 0.2);"]Total Modifier[/th]
                        [th style="color:#ffd700; text-align:center; padding:10px; border-bottom:1px ridge rgba(255, 255, 255, 0.2); border-right:1px ridge rgba(255, 255, 255, 0.2);"]Optimal Use[/th]
                    [/tr]
