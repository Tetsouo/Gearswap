                        ([color=#cea425]159%[/color] + [color=#00ffd0]30%[/color])[/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border:1px ridge rgba(255, 255, 255, 0.2);"][size=10][i][color=#ff7f50]2189[/color] × [color=#ff7f50]1.89[/color] =[/i][/size] [color=#ff7f50]4137 VE[/color][/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border:1px ridge rgba(255, 255, 255, 0.2);"][size=10][i][color=#ff9966]308[/color] × [color=#ff9966]1.89[/color] =[/i][/size] [color=#ff9966]582 CE[/color][/td]
                    [/tr]
                    [tr style="background-color:#333333;"]
