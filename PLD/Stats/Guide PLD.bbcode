                                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#F7D58B]R15 Burtgang (2000 TP)[/color][/td]
                                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ff9966]750[/color][/td]
                                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ff7f50]2250[/color][/td]
                                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070;"][color=#ff7f50]3000[/color][/td]
                                    [/tr]
                                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#F7D58B]R15 Burtgang (3000 TP)[/color][/td]
