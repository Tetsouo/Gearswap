                        ([color=#cea425]159%[/color] + [color=#00ffd0]30%[/color])[/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][size=10][i][color=#ff7f50]900[/color] × [color=#ff7f50]2.89[/color] =[/i][/size] [color=#ff7f50]2601 VE[/color][/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][size=10][i][color=#ff9966]450[/color] × [color=#ff9966]2.89[/color] =[/i][/size] [color=#ff9966]1300 CE[/color][/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="color:#00ffd0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Foil[/td]
                        [td style="color:#00ffd0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Magic[/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#cea425]Full Enmity[/color] + [color=#00ffd0]Crusade[/color]
                        ([color=#cea425]159%[/color] + [color=#00ffd0]30%[/color])[/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][size=10][i][color=#ff7f50]880[/color] × [color=#ff7f50]2.89[/color] =[/i][/size] [color=#ff7f50]2543 VE[/color][/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][size=10][i][color=#ff9966]320[/color] × [color=#ff9966]2.89[/color] =[/i][/size] [color=#ff9966]924 CE[/color][/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="color:#e5d522; text-align:center; padding:5px; border-right:1px solid #707070;"]Swordplay[/td]
                        [td style="color:#e5d522; text-align:center; padding:5px; border-right:1px solid #707070;"]JA[/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-right:1px solid #707070;"][color=#cea425]Full Enmity[/color] + [color=#00ffd0]Crusade[/color]
                        ([color=#cea425]159%[/color] + [color=#00ffd0]30%[/color])[/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-right:1px solid #707070;"][size=10][i][color=#ff7f50]320[/color] × [color=#ff7f50]2.89[/color] =[/i][/size] [color=#ff7f50]924 VE[/color][/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-right:1px solid #707070;"][size=10][i][color=#ff9966]160[/color] × [color=#ff9966]2.89[/color] =[/i][/size] [color=#ff9966]462 CE[/color][/td]
                    [/tr]
                    [tr style="background: linear-gradient(to top, #b08d57, #806a38); box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.6);"]
                        [th colspan="7" style="text-align:center; font-size:18px; text-transform:uppercase; font-weight:bold; color:#332b05; text-shadow:0 0 1px #806a35, 0px 0px 2px #b7974d;"]Warrior (Sub Job)[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="color:#e5d522; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Provoke[/td]
                        [td style="color:#e5d522; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"]JA[/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#cea425]Full Enmity[/color] + [color=#00ffd0]Crusade[/color]
                        ([color=#cea425]159%[/color] + [color=#00ffd0]30%[/color])[/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][size=10][i][color=#ff7f50]1800[/color] × [color=#ff7f50]2.89[/color] =[/i][/size] [color=#ff7f50]5202 VE[/color][/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ff9966]1[/color][/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="color:#e5d522; text-align:center; padding:5px; border-right:1px solid #707070;"]Warcry[/td]
                        [td style="color:#e5d522; text-align:center; padding:5px; border-right:1px solid #707070;"]JA[/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-right:1px solid #707070;"][color=#cea425]Full Enmity[/color] + [color=#00ffd0]Crusade[/color]
                        ([color=#cea425]159%[/color] + [color=#00ffd0]30%[/color])[/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-right:1px solid #707070;"][size=10][i][color=#ff7f50]320[/color] × [color=#ff7f50]2.89[/color] =[/i][/size] [color=#ff7f50]924 VE[/color] (per member affected)[/td]
                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-right:1px solid #707070;"][color=#ff9966]0[/color][/td]
                    [/tr]
                [/table][/div]
        [/div]
        

        [div style="
        background-color:rgba(254, 254, 254, 0.1); 
        padding:10px; 
        border-radius:10px; 
        border:2px ridge rgba(255, 255, 255, 0.7); 
        box-shadow: inset 0 0 20px rgba(0, 0, 0, 1), 0 0 20px rgba(0, 0, 0, 0.5);
        color:#E0E0E0;
        text-align:left;"][div align="center"][div id=pld-aggro-basics style="
                font-size:20px; 
                color: #cea425; 
                text-shadow: 0px 0px 2px 10px #967616;"]Basic Principles of Effective Aggro Generation
                    [url=#top style="font-size:14px; color:#2980B9"]▲ Back to top ▲[/url]
                [/div]

                [div align="left"]Managing Aggro effectively is the cornerstone of a Paladin's role in any combat scenario.  
                    Ensuring that enemies focus their attacks on you and not on vulnerable party members requires a strategic balance of Spells, Job Abilities (JAs), and gear.  

                    This section provides a foundational guide on how to generate and maintain Aggro using single-target and AoE strategies.
                    By mastering these principles, you will not only solidify your position as the primary tank but also ensure your party’s safety and efficiency during encounters.  

                    Whether dealing with single targets or multiple enemies, understanding the nuances of Volatile Enmity (VE) and Cumulative Enmity (CE) will make you a more reliable and effective tank.[/div]
                
                [table style="border:3px ridge #b08d57; box-shadow: inset 0 0 6px #5b4b2d;"]
                    [tr style="background: linear-gradient(to top, #b08d57, #806a38); box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.6);"]
                        [th colspan="7" style="text-align:center; font-size:18px; text-transform:uppercase; font-weight:bold; color:#332b05; text-shadow:0 0 1px #806a35, 0px 0px 2px #b7974d;"]Single Target Priority[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [th style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070; color: #ffd700;"]Action[/th]
                        [th style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070; color: #ffd700;"]Objective[/th]
                        [th style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070; color: #ffd700;"][color=#ffa07a]VE[/color] Generated[/th]
                        [th style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070; color: #ffd700;"][color=#ffa366]CE[/color] Generated[/th]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#e5d522]Divine Emblem[/color] + [color=#00ffd0]Flash[/color][/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Initial aggro spike to quickly add yourself to the hate list.[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ffa07a]6326[/color] (with Chevalier's Sabatons +3)[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ffa366]890[/color][/td]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#e5d522]Sentinel[/color] + [color=#e5d522]Palisade[/color] or [color=#e5d522]Rampart[/color][/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Boost [color=#ff7f50]Enmity+[/color] with [color=#e5d522]Sentinel[/color] and deliver a significant spike using [color=#e5d522]Palisade[/color] or [color=#e5d522]Rampart[/color].[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#e5d522]Palisade[/color]: [color=#ffa07a]5202[/color] / [color=#e5d522]Rampart[/color]: [color=#ffa07a]924[/color] per member affected[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#e5d522]Palisade[/color]: [color=#ffa366]2601[/color] / [color=#e5d522]Rampart[/color]: [color=#ffa366]924[/color] per member affected[/td]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#e5d522]Shield Bash[/color][/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Maintain aggro while delivering a solid VE/CE spike.[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ffa07a]1300[/color][/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ffa366]2601[/color][/td]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#00ffd0]Flash[/color] or [color=#00ffd0]Jettatura[/color][/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Maintain steady aggro while delivering consistent spikes of [color=#ffa07a]VE[/color] and [color=#ffa366]CE[/color].[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#00ffd0]Flash[/color]: [color=#ffa07a]3699[/color] / [color=#00ffd0]Jettatura[/color]: [color=#ffa07a]2959[/color][/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ffa366]520 CE[/color][/td]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; text-align:center; border-right:1px solid #707070;"][color=#00ffd0]Blank Gaze → Geist Wall → Sheep Song[/color][/td]
                        [td style="padding:5px; text-align:center; border-right:1px solid #707070;"]Alternate to maintain aggro while waiting for cooldowns.[/td]
                        [td style="padding:5px; text-align:center; border-right:1px solid #707070;"]Each generates [color=#ffa07a]780 VE[/color][/td]
                        [td style="padding:5px; text-align:center; border-right:1px solid #707070;"]Each generates [color=#ffa366]780 CE[/color][/td]
                    [/tr]
                    [tr style="background: linear-gradient(to top, #b08d57, #806a38); box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.6);"]
                        [th colspan="7" style="text-align:center; font-size:18px; text-transform:uppercase; font-weight:bold; color:#332b05; text-shadow:0 0 1px #806a35, 0px 0px 2px #b7974d;"]Multiple Target Priority[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [th style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070; color: #ffd700;"]Action[/th]
                        [th style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070; color: #ffd700;"]Objective[/th]
                        [th style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070; color: #ffd700;"][color=#ffa07a]VE[/color] Generated[/th]
                        [th style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070; color: #ffd700;"][color=#ffa366]CE[/color] Generated[/th]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#00ffd0]Sheep Song[/color], [color=#00ffd0]Geist Wall[/color], or [color=#00ffd0]Cold Wave[/color][/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Open with an [color=#00ffd0]AoE spell[/color] to ensure all enemies are aware of your presence and add you to their hate lists.[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ffa07a]780 VE[/color] per target[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ffa366]780 CE[/color] per target[/td]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#e5d522]Sentinel[/color] + [color=#e5d522]Palisade[/color] or [color=#e5d522]Rampart[/color][/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Boost [color=#ff7f50]Enmity+[/color] with [color=#e5d522]Sentinel[/color] and deliver a significant spike using [color=#e5d522]Palisade[/color] or [color=#e5d522]Rampart[/color].[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#e5d522]Palisade[/color]: [color=#ffa07a]5202[/color] / [color=#e5d522]Rampart[/color]: [color=#ffa07a]924[/color] per member affected[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#e5d522]Palisade[/color]: [color=#ffa366]2601[/color] / [color=#e5d522]Rampart[/color]: [color=#ffa366]924[/color] per member affected[/td]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#00ffd0]Jettatura[/color][/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Supplement your aggro generation with a conal AoE spike. Ensure proper positioning to avoid unintended targets.[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ffa07a]2959 VE[/color] total[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ffa366]520 CE[/color] total[/td]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#00ffd0]Sheep Song → Geist Wall → Cold Wave[/color][/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Rotate between these spells to maintain aggro while waiting for cooldowns.[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Each generates [color=#ffa07a]780 VE[/color] per target[/td]
                        [td style="padding:5px; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Each generates [color=#ffa366]780 CE[/color] per target[/td]
                    [/tr]
                [/table][/div][/div]
    [/div]


    [div style="
    margin:0 auto; 
    background-color:rgba(26, 26, 26, 0.85); 
    padding:5px; 
    border-radius:15px;
    box-shadow: 0 0 5px rgba(0, 0, 0, 1); 
    border:3px ridge #F7D58B;
    "][div align="center" style="margin:15px 0 25px 0; padding:10px;"][img style="width:450px; height:auto;"]https://i.imgur.com/Rd4V1im.png[/img]
            [span style="
            font-size:25px;
            font-family:Garamond, serif;
            font-weight:bold; 
            color:#FFD700; 
            text-transform:uppercase; 
            letter-spacing:1px;
            text-shadow:0 0 1px #5a4614, 1px 1px 2px #7b6119;"]DEFENSE[/span]
        [/div]

        [div style="
        background-color:rgba(254, 254, 254, 0.1); 
        padding:10px; 
        border-radius:10px; 
        border:2px ridge rgba(255, 255, 255, 0.7); 
        box-shadow: inset 0 0 20px rgba(0, 0, 0, 1), 0 0 20px rgba(0, 0, 0, 0.5);
        color:#E0E0E0;
        text-align:left;"][div align="center"][div id=pld-damage-taken style="
                font-size:20px; 
                color: #cea425; 
                text-shadow: 0px 0px 2px 10px #967616;"]Damage Taken Reduction Mechanics
                    [url=#top style="font-size:14px; color:#2980B9"]▲ Back to top ▲[/url]
                [/div]

                [div align="left"][color=#cea425][b]Damage Taken (DT):[/b][/color]
                    • A global reduction applied to all types of damage.  
                    • Maximum cap: -50%.  
                    • Reduces all damage before applying specific reductions (e.g., PDT, MDT).  

                    [color=#cea425][b]Physical Damage Taken (PDT):[/b][/color]
                    • Applies only to physical attacks.  
                    • Cap: -50%, extendable with PDT II.  
                    • PDT II (e.g., Burtgang) allows reductions beyond the standard limit.  

                    [color=#cea425][b]Magical Damage Taken (MDT):[/b][/color]
                    • Specific to magical attacks.  
                    • Cap: -50%, extendable with MDT II.  
                    • Tools like Aegis extend reductions up to -87.5%.  

                    [color=#cea425][b]Advanced Reductions:[/b][/color]
                    • Special tools like Burtgang or Aegis allow surpassing conventional caps.  
                    • These reductions are critical for mitigating extreme damage scenarios.
                [/div]

                [table style="border:3px ridge #b08d57; box-shadow: inset 0 0 6px #5b4b2d;"]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; color:#ffd700;"]Type[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; color:#ffd700;"]Cap[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; color:#ffd700;"]Formula[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; color:#ffd700;"]Notes[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"][color=#F7D58B]Damage Taken (DT):[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"]-50%[/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"]Applies to all damage types[/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left;"]Combines with [color=#F7D58B]PDT[/color], [color=#F7D58B]MDT[/color], or [color=#F7D58B]BDT[/color] to reach their caps.[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"][color=#F7D58B]Physical Damage Taken (PDT):[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"]-50%[/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"](Uncorrected Damage) × (100% - [color=#F7D58B]PDT[/color] - [color=#F7D58B]DT[/color])[/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left;"]Use [color=#66ccff]Burtgang[/color] ([color=#F7D58B]-18% PDT II[/color]) for up to [color=#F7D58B]68%[/color] reduction.[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"][color=#F7D58B]Magical Damage Taken (MDT):[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"]-50%[/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"]Floor((Magic Damage) × (100% - [color=#F7D58B]MDT[/color] - [color=#F7D58B]DT[/color])) ÷ (1 + [color=#F7D58B]MDB[/color] ÷ 100)[/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left;"]Use [color=#66ccff]Aegis[/color] ([color=#F7D58B]-50% MDT II[/color]) for up to [color=#F7D58B]87.5%[/color] reduction.[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"][color=#F7D58B]Breath Damage Taken (BDT):[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"]-50%[/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"](Breath Base Damage) × (1 - [color=#F7D58B]BDT[/color] - [color=#F7D58B]DT[/color] - [color=#F7D58B]MDT[/color] augmentations)[/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left;"]Gear with [color=#F7D58B]MDT[/color] augments helps reduce breath damage.[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"][color=#F7D58B]PDT II/MDT II:[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"]Up to -87.5%[/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center;"]Special reductions beyond standard [color=#F7D58B]PDT/MDT[/color] caps[/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left;"]Examples: [color=#66ccff]Burtgang[/color] ([color=#F7D58B]PDT II[/color]), [color=#66ccff]Aegis[/color] ([color=#F7D58B]MDT II[/color]).[/td]
                    [/tr]
                [/table]
                [table style="border:3px ridge #b08d57; box-shadow: inset 0 0 6px #5b4b2d;"]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle; color: #ffd700;"]Example[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle; color: #ffd700;"]Details[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle; color: #ffd700;"]Corrected Damage[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle; color: #ffd700;"]Explanation[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle;"][color=#F7D58B]Physics[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle;"]-50% [color=#F7D58B]PDT[/color]  
                            -18% [color=#F7D58B]PDT II[/color]
                        [/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle;"]1000 × (1 - 0.50 - 0.18)  
                            320 damage taken
                        [/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle;"][color=#F7D58B]PDT[/color] caps at [color=#F7D58B]-50%[/color], but [color=#F7D58B]PDT II[/color] allows reductions beyond the cap.  
                            This results in further reduced physical damage.
                        [/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle;"][color=#F7D58B]Magics[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle;"]-50% [color=#F7D58B]MDT[/color]  
                            -50% [color=#F7D58B]MDT II[/color]  
                            [color=#F7D58B]MDB[/color] +20
                        [/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle;"]Floor((1000 × (1 - 0.50 - 0.375)) ÷ (1 + 20 ÷ 100))  
                            104 damage taken
                        [/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle;"][color=#F7D58B]MDT[/color] reduces by [color=#F7D58B]-50%[/color] initially.  
                            [color=#F7D58B]MDT II[/color] adds [color=#F7D58B]-37.5%[/color], reaching the cap of [color=#F7D58B]-87.5%[/color].  
                            [color=#F7D58B]MDB[/color] further divides the remaining damage by its bonus percentage.
                        [/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle;"][color=#F7D58B]Breaths[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle;"]-50% [color=#F7D58B]DT[/color]  
                            -30% [color=#F7D58B]BDT[/color]  
                            -10% [color=#F7D58B]MDT[/color] augmentations
                        [/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle;"]1000 × (1 - 0.50)  
                            500 damage taken
                        [/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align: center; vertical-align: middle;"][color=#F7D58B]DT[/color] already caps at [color=#F7D58B]-50%[/color], applying globally to all damage types.  
                            Contributions from [color=#F7D58B]BDT[/color] and [color=#F7D58B]MDT[/color] are not applied further.
                        [/td]
                    [/tr]
                [/table][/div]
        [/div]
        

        [div style="
        background-color:rgba(254, 254, 254, 0.1); 
        padding:10px; 
        border-radius:10px; 
        border:2px ridge rgba(255, 255, 255, 0.7); 
        box-shadow: inset 0 0 20px rgba(0, 0, 0, 1), 0 0 20px rgba(0, 0, 0, 0.5);
        color:#E0E0E0;
        text-align:left;"][div align="center"][div id=pld-physicals-dmg style="
                font-size:20px; 
                color: #cea425; 
                text-shadow: 0px 0px 2px 10px #967616;"]Physical Damage Mitigation
                    [url=#top style="font-size:14px; color:#2980B9"]▲ Back to top ▲[/url]
                [/div]

                [div align="left"]Optimizing Physical Damage Mitigation for a Paladin involves careful management of DEF, Shield Mechanics, and Critical Hit Mitigation. Below is a structured summary:[/div]
                [div align="center"]
                    [table style="border:3px ridge #b08d57; box-shadow: inset 0 0 6px #5b4b2d;"]
                        [tr style="background: linear-gradient(to top, #b08d57, #806a38); box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.6);"]
                            [th colspan="7" style="text-align:center; font-size:18px; text-transform:uppercase; font-weight:bold; color:#332b05; text-shadow:0 0 1px #806a35, 0px 0px 2px #b7974d;"]Defense (DEF)[/th]
                        [/tr]
                        [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                            [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Aspect[/th]
                            [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Description[/th]
                        [/tr]
                        [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                            [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Base DEF[/color][/td]
                            [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]Calculated using level and Vitality (VIT).  
                            Formula: [i]Base DEF = floor(VIT × 1.5) + level adjustment[/i][/td]
                        [/tr]
                        [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                            [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Equipment DEF[/color][/td]
                            [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]Direct addition of DEF values from equipment.[/td]
                        [/tr]
                        [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                            [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Active Buffs[/color][/td]
                            [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"][color=#00ffd0]Protect V[/color]: Adds 220 DEF (+ shield DEF when cast by Paladin).  
                            Example: Shield with 130 DEF results in a total of 350 DEF.  
                            [color=#00ffd0]Cocoon[/color]: Boosts DEF by 50% (Blue Mage Spell).[/td]
                        [/tr]
                        [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                            [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Impact on Attack/DEF Ratio[/color][/td]
                            [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]A higher Attack/DEF ratio increases incoming damage.  
                            A lower ratio reduces damage, with higher DEF providing better mitigation.[/td]
                        [/tr]
                    [tr style="background: linear-gradient(to top, #b08d57, #806a38); box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.6);"]
                        [th colspan="7" style="text-align:center; font-size:18px; text-transform:uppercase; font-weight:bold; color:#332b05; text-shadow:0 0 1px #806a35, 0px 0px 2px #b7974d;"]Shield Mechanics[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Aspect[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Description[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Shield Skill Mechanics[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]Shields block physical attacks from the front.  
                        Formula: BlockRate = BaseRate + ((ShieldSkill - AttackerSkill) × 0.2325).  
                        Example: Shield Skill 420 and BaseRate 45% → Block Rate = 49.65%.  
                        Ultimate Shields: Specific shields like Aegis ignore conventional rules.
                        [/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Damage Reduction[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]Formula: PercentDamageBlocked = SizeDamageReduction + (ShieldDEF / X).  
                        X varies depending on shield level:  
                        • Non-ilvl shields: ShieldDEF/2.  
                        • ilvl 119 shields: ShieldDEF/4.  
                        Final Damage Taken: BaseDamage × (1 - Reduction/100).  
                        [/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Damage Reduction on Block[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]Formula: FinalDamage = (BaseDamage - ShieldBonus) × (1 - BlockPercent/100).  
                        Example: 1000 damage, 60% reduction, and 30% PDT = 280 final damage.  
                        [/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Abilities[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• Reprisal: Increases block rate by 50% (or 3x with Priwen).  
                        • Palisade: Adds 30% block rate (+20% merits), prevents hate loss on block.  
                        [/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Standard Shields[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][table width="100%" style="border:3px ridge #b08d57; box-shadow: inset 0 0 6px #5b4b2d;"]
                                [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                    [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Shield[/th]
                                    [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Size[/th]
                                    [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Total Damage Reduction[/th]
                                    [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Base Block Rate[/th]
                                [/tr]
                                [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][img]https://www.bg-wiki.com/images/d/db/Dynamis_Shield_icon.png[/img]
                                    [/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]1[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]-20%[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]55%[/td]
                                [/tr]
                                [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][img]https://www.bg-wiki.com/images/1/12/Chef%27s_Ecu_icon.png[/img]
                                    [/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]2[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]-40%[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]40%[/td]
                                [/tr]
                                [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][img]https://www.bg-wiki.com/images/9/9d/Jennet_Shield_icon.png[/img]
                                    [/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]3[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]-50%[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]45%[/td]
                                [/tr]
                                [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][img]https://www.bg-wiki.com/images/1/18/Scutum_icon.png[/img]
                                    [/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]4[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]-65%[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]30%[/td]
                                [/tr]
                            [/table][/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Ultimate Shields[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][table width="100%" style="border:3px ridge #b08d57; box-shadow: inset 0 0 6px #5b4b2d;"]
                                [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                    [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Shield[/th]
                                    [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Total Damage Reduction[/th]
                                    [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Base Block Rate[/th]
                                [/tr]
                                [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][img]https://www.bg-wiki.com/images/c/c2/Aegis_%28Level_75%29_icon.png[/img]
                                    Aegis[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]-75%[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]50%[/td]
                                [/tr]
                                [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][img]https://www.bg-wiki.com/images/1/1c/Srivatsa_icon.png[/img]
                                    Srivatsa[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]-75%[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]50%[/td]
                                [/tr]
                                [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][img]https://www.bg-wiki.com/images/a/a2/Ochain_%28Level_85%29_icon.png[/img]
                                    Ochain[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]-60%[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]~108%[/td]
                                [/tr]
                                [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][img]https://www.bg-wiki.com/images/a/ab/Duban_%28Incomplete%29_icon.png[/img]
                                    Duban[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]-60%[/td]
                                    [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]~108%[/td]
                                [/tr]
                            [/table][/td]
                    [/tr]
                    [tr style="background: linear-gradient(to top, #b08d57, #806a38); box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.6);"]
                        [th colspan="7" style="text-align:center; font-size:18px; text-transform:uppercase; font-weight:bold; color:#332b05; text-shadow:0 0 1px #806a35, 0px 0px 2px #b7974d;"]Enemy Critical Hit Rate[/th]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Aspect[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Details[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Critical Hit Rate Reduction[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"][color=#F7D58B]Enemy critical hit rate[/color] is a merit category available to all jobs. Each merit upgrade grants a 1% reduction in critical hit rate from enemies, up to a maximum of 5% reduction.  
                        This costs 15 merits for a full upgrade (1 > 2 > 3 > 4 > 5).  
                        [/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Critical Hit Rate Formula[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"][color=#F7D58B]Enemy critical hit rate[/color] seems to be calculated similarly to Player Critical Hit Rate, but uses the Enemy's DEX and the Player's AGI.  
                        • Higher AGI reduces the Enemy's critical hit rate.  
                        • Minimum critical hit rate: 1%.  
                        • Cap on [color=#F7D58B]Enemy critical hit rate[/color]: 10% (exceptions apply).  
                        • To reduce a capped 10% critical hit rate to the minimum of 1%, 9% reduction is required.  
                        [/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Reduction Calculation[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]Example:  
                        • Merits (5/5): -5%.  
                        • Fortified Ring: -7%.  
                        Total reduction = 12%, reducing 10% to 1%.  
                        Avoid overcapping by carefully balancing gear and merits.  
                        [/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Recommended Equipment[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• [color=#66ccff]Warden's Ring[/color]: Enemy critical hit rate -5%, "Death" resistance +10, Physical damage taken -3%.  
                        • [color=#66ccff]Eluder's Sachet[/color]: Enemy critical hit rate -5%, Damage taken +2%.  
                        • [color=#66ccff]Fortified Ring[/color]: Enemy critical hit rate -7%, MP+50, Accuracy+5, Magic damage taken -5%.  
                        [/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Importance for Tanks[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]Tanks can reduce the spike damage from critical hits by equipping items with Enemy critical hit rate reduction.  
                        • Particularly useful in situations with [color=#00ffd0]Phalanx[/color], where overall damage can approach zero.  
                        • Focus on reducing critical hit spikes for greater stability.  
                        [/td]
                    [/tr]
                [/table]
            [/div]
        [/div]
    [/div]
        

        [div style="
        background-color:rgba(254, 254, 254, 0.1); 
        padding:10px; 
        border-radius:10px; 
        border:2px ridge rgba(255, 255, 255, 0.7); 
        box-shadow: inset 0 0 20px rgba(0, 0, 0, 1), 0 0 20px rgba(0, 0, 0, 0.5);
        color:#E0E0E0;
        text-align:left;"][div align="center"][div id=pld-magical-dmg style="
                font-size:20px; 
                color: #cea425; 
                text-shadow: 0px 0px 2px 10px #967616;"]Magical Damage Mitigation
                    [url=#top style="font-size:14px; color:#2980B9"]▲ Back to top ▲[/url]
                [/div]

                [table style="border:3px ridge #b08d57; box-shadow: inset 0 0 6px #5b4b2d;"]
                    [tr style="background: linear-gradient(to top, #b08d57, #806a38); box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.6);"]
                            [th colspan="7" style="text-align:center; font-size:18px; text-transform:uppercase; font-weight:bold; color:#332b05; text-shadow:0 0 1px #806a35, 0px 0px 2px #b7974d;"]Elemental Resistance[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Aspect[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Description[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Importance and Scenarios[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• Negative Resistance guarantees at least 1/2 damage
                            • Positive Resistance, with MEVA, enables full resist (1/8 damage)
                            • Bar-spells boost resistance for specific elemental threats[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Application for PLD[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• [color=#66ccff]Carrier's Sash[/color] offers broad elemental resistance
                            • [color=#66ccff]Warden's Charm[/color] / [color=#66ccff]+1[/color] helps manage multiple elemental resistances
                            • [color=#00ffd0]Bar-spells[/color] for specific vulnerabilities[/td]
                    [/tr]
                    [tr style="background: linear-gradient(to top, #b08d57, #806a38); box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.6);"]
                            [th colspan="7" style="text-align:center; font-size:18px; text-transform:uppercase; font-weight:bold; color:#332b05; text-shadow:0 0 1px #806a35, 0px 0px 2px #b7974d;"]Magic Defense Bonus (MDB)[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Aspect[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Details[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]General Description[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• Formula: Final Damage = Base Damage × (100 + MAB) ÷ (100 + MDB)
                            • Applies to all magical damage including Quick Draw and elemental WSs[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Limitations[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• Does not affect breath attacks
                            • Same-tier traits do not stack
                            • No known cap[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Enemy Interaction[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• Enemy MAB can exceed 900 in extreme cases
                            • Most enemies lack MDB except NMs[/td]
                    [/tr]
                    [tr style="background: linear-gradient(to top, #b08d57, #806a38); box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.6);"]
                            [th colspan="7" style="text-align:center; font-size:18px; text-transform:uppercase; font-weight:bold; color:#332b05; text-shadow:0 0 1px #806a35, 0px 0px 2px #b7974d;"]Damage Calculation Order[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Step[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Details[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]1. Magic Evasion[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• Determines initial resist state:
                            • Full Hit → All damage
                            • Partial Resist → 1/2 or 1/4 damage
                            • Full Resist → 1/8 damage[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]2. Elemental Resistance[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• Modifies resist state:
                            • Negative → Forces minimum 1/2 damage
                            • Positive → Enables full resists with MEVA[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]3. Magic Damage Taken[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• Formula: Remaining = Base × (1 - MDT)
                            • Caps at 50% (87.5% with Aegis)[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]4. Magic Defense Bonus[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• Final calculation using MDB formula
                            • Last layer of defense[/td]
                    [/tr]
                [/table][/div]
        [/div]
        

        [div style="
        background-color:rgba(254, 254, 254, 0.1); 
        padding:10px; 
        border-radius:10px; 
        border:2px ridge rgba(255, 255, 255, 0.7); 
        box-shadow: inset 0 0 20px rgba(0, 0, 0, 1), 0 0 20px rgba(0, 0, 0, 0.5);
        color:#E0E0E0;
        text-align:left;"][div align="center"][div id=pld-phalanx style="
                font-size:20px; 
                color: #cea425; 
                text-shadow: 0px 0px 2px 10px #967616;"]Phalanx Mechanics and Usage
                    [url=#top style="font-size:14px; color:#2980B9"]▲ Back to top ▲[/url]
                [/div]
            [/div]

            [div align="left"]Phalanx is a powerful defensive enhancement that applies a flat damage reduction to incoming hits. This reduction occurs at the very end of all damage calculations, making it particularly effective at eliminating residual damage. With a well-optimized Phalanx Potency set, most incoming hits will be reduced to zero or negligible amounts, making it one of the Paladin's most powerful defensive tools.

                Once all other damage calculations are complete (PDT, MDT, resistances, etc.), Phalanx subtracts its fixed value from the remaining damage. Since many end-game hits are already heavily mitigated by your other defensive mechanics, Phalanx often represents the difference between taking small damage and no damage at all.

                [color=#cea425][b]Advanced Tip:[/b][/color]
                • When paired with a Red Mage, you can combine the best of both jobs by synchronizing your Phalanx casts:
                • The PLD provides high potency from their gear set
                • The RDM contributes enhanced duration
                • Coordinate using a countdown "3, 2, 1" and cast simultaneously
                • Result: You get your potency with RDM's extended duration.
            [/div]

            [div align="center"]
                [table style="border:3px ridge #b08d57; box-shadow: inset 0 0 6px #5b4b2d;"]
                    [tr style="background: linear-gradient(to top, #b08d57, #806a38); box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.6);"]
                        [th colspan="7" style="text-align:center; font-size:18px; text-transform:uppercase; font-weight:bold; color:#332b05; text-shadow:0 0 1px #806a35, 0px 0px 2px #b7974d;"]Phalanx Mechanics[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Aspect[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle; color:#ffd700;"]Description[/th]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Core Mechanics[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• [color=#00ffd0]Phalanx[/color] reduces damage by a fixed amount based on [color=#00ffd0]Enhancing Magic skill[/color]
                            [u][b]Damage reduction formula:[/b][/u]
                                • Up to 300 skill: Floor(Skill/10) - 2
                                • Over 300 skill: 28 + Floor((Skill - 300.5)/28.5)[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Equipment Bonus[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• [color=#66ccff]Phalanx+ gear bonuses[/color] directly add to damage reduction
                            • Equipment must be worn when receiving [color=#00ffd0]Phalanx[/color]
                            • Effect persists even after gear swap[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Important Thresholds[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"]
                            [table width="100%" style="
                            border-collapse: collapse;
                            font-size: 12px;
                            margin: 0 auto;
                            line-height:1.5;"]
                                [tr style="background-color:rgba(26, 26, 26, 0.5);"][th style="border:1px solid #707070; text-align:center; color:#ffd700;"]Skill Level[/th]
                                    [th style="padding:5px; border:1px solid #707070; text-align:center; color:#ffd700;"]300[/th]
                                    [th style="padding:5px; border:1px solid #707070; text-align:center; color:#ffd700;"]329[/th]
                                    [th style="padding:5px; border:1px solid #707070; text-align:center; color:#ffd700;"]358[/th]
                                    [th style="padding:5px; border:1px solid #707070; text-align:center; color:#ffd700;"]386[/th]
                                    [th style="padding:5px; border:1px solid #707070; text-align:center; color:#ffd700;"]415[/th]
                                    [th style="padding:5px; border:1px solid #707070; text-align:center; color:#ffd700;"]500[/th][/tr]
                                [tr style="background-color:rgba(26, 26, 26, 0.5);"][td style="border:1px solid #707070; text-align:center; color:#d64848;"]Damage Reduction[/td]
                                    [td style="padding:5px; border:1px solid #707070; text-align:center; color:#7fe07f;"]-28[/td]
                                    [td style="padding:5px; border:1px solid #707070; text-align:center; color:#7fe07f;"]-29[/td]
                                    [td style="padding:5px; border:1px solid #707070; text-align:center; color:#7fe07f;"]-30[/td]
                                    [td style="padding:5px; border:1px solid #707070; text-align:center; color:#7fe07f;"]-31[/td]
                                    [td style="padding:5px; border:1px solid #707070; text-align:center; color:#7fe07f;"]-32[/td]
                                    [td style="padding:5px; border:1px solid #707070; text-align:center; color:#7fe07f;"]-35[/td]
                                [/tr]
                            [/table]
                        [/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Damage Calculation[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• [color=#00ffd0]Phalanx[/color] reduction is applied after [color=#ffb380]Damage Taken[/color] equipment
                            • Example: 100 damage with [color=#00ffd0]Phalanx[/color] -20 becomes 80 damage[/td]
                    [/tr]
                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][color=#F7D58B]Optimization Note[/color][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]• Skills between tiers provide no additional benefit
                            • Example: 410 skill gives same reduction as 386 skill (-31)
                            • Plan gear and buffs to reach specific thresholds[/td]
                    [/tr]
                [/table]
            [/div]
        [/div]
    [/div]
    
    
    [div style="
    margin:0 auto; 
    background-color:rgba(26, 26, 26, 0.85); 
    padding:5px; 
    border-radius:15px;
    box-shadow: 0 0 5px rgba(0, 0, 0, 1); 
    border:3px ridge #F7D58B;"][div align="center" style="margin:15px 0 25px 0; padding:10px;"][img style="width:450px; height:auto;"]https://i.imgur.com/Rd4V1im.png[/img]
    [span style="
            font-size:25px;
            font-family:Garamond, serif;
            font-weight:bold; 
            color:#FFD700; 
            text-transform:uppercase; 
            letter-spacing:1px;
            text-shadow:0 0 1px #5a4614, 1px 1px 2px #7b6119;"]EQUIPMENT[/span]
        [/div]

        [div style="
        background-color:rgba(254, 254, 254, 0.1); 
        padding:10px; 
        border-radius:10px; 
        border:2px ridge rgba(255, 255, 255, 0.7); 
        box-shadow: inset 0 0 20px rgba(0, 0, 0, 1), 0 0 20px rgba(0, 0, 0, 0.5);
        color:#E0E0E0;
        text-align:left;"][div align="center"][div id=pld-hp-management style="
                font-size:20px; 
                color: #cea425; 
                text-shadow: 0px 0px 2px 10px #967616;"]HP Management and Optimization
                    [url=#top style="font-size:14px; color:#2980B9"]▲ Back to top ▲[/url]
                [/div]
            [/div]

            [div align="left"][color=#cea425][b]Optimizing HP Management During Gear Swaps:[/b][/color]
                Proper gear swapping is essential to maintain optimal HP during combat. The gear swap cycle differs depending on the action performed:

                [color=#cea425][b]For Spells (Magic):[/b][/color]  
                When casting a spell, the gear transition follows this cycle:
            [/div]

            [div align="center"][table style="border:3px ridge #b08d57; box-shadow: inset 0 0 6px #5b4b2d;"]
                    [tr style="background: linear-gradient(to top, #b08d57, #806a38); box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.6);"]
                        [th colspan="7" style="text-align:center; font-size:18px; text-transform:uppercase; font-weight:bold; color:#332b05; text-shadow:0 0 1px #806a35, 0px 0px 2px #b7974d;"]Complete Casting Cycle for Magic Spells[/th]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700; "]Step[/th]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700;"]Explanation[/th]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][b][color=#F7D58B]Idle Phase[/color][/b][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]The character is in a neutral state, waiting for action.[/td]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][b][color=#F7D58B]Precast Phase[/color][/b][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]The moment when the spell is initiated, focusing on reducing casting time (Fast Cast effect).[/td]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][b][color=#F7D58B]Midcast Phase[/color][/b][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]The spell is being cast. The spell's potency, duration, or accuracy is determined here.[/td]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][b][color=#F7D58B]Return to Idle[/color][/b][/td]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:left; vertical-align:middle;"]After the spell is completed, the character returns to the idle state, ready for the next action.[/td]
                    [/tr]

                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [td style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle;"][b][color=#F7D58B]Visual Representation[/color][/b][/td]
