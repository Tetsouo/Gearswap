    "][div align="center" style="margin:15px 0 25px 0; padding:10px;"][img style="width:450px; height:auto;"]https://i.imgur.com/Rd4V1im.png[/img]
            [span style="
            font-size:25px;
            font-family:Garamond, serif;
            font-weight:bold; 
            color:#FFD700; 
            text-transform:uppercase; 
            letter-spacing:1px;
            text-shadow:0 0 1px #5a4614, 1px 1px 2px #7b6119;"]ENMITY[/span]
