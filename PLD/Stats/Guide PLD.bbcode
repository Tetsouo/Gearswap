                                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#F7D58B]R15 Burtgang (1000 TP)[/color][/td]
                                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ff9966]600[/color][/td]
                                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ff7f50]1800[/color][/td]
                                        [td style="color:#E0E0E0; text-align:center; padding:5px; border-bottom:1px solid #707070;"][color=#ff7f50]2400[/color][/td]
                                    [/tr]
