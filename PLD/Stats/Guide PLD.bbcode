                    [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                        [th style="padding:5px; border-bottom:1px solid #707070; border-right:1px solid #707070; text-align:center; vertical-align:middle; color:#ffd700; "]Step[/th]
