                                            [th style="color:#ffd700; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]HP Healed[/th]
                                            [th style="color:#ffd700; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Base CE(HP × 0.231)[/th]
                                            [th style="color:#ffd700; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]CE(+57/+30 Enmity)[/th]
                                            [th style="color:#ffd700; text-align:center; border-bottom:1px solid #707070;"]Final VE(CE × 6)[/th]
                                        [/tr]
                                        [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                            [td style="color:#E0E0E0; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#00ffd0]Cure IV[/color][/td]
                                            [td style="color:#E0E0E0; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#7fe07f]783[/color][/td]
                                            [td style="color:#E0E0E0; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ffa366]180.9[/color][/td]
                                            [td style="color:#E0E0E0; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#ffa366]426.1[/color][/td]
                                            [td style="color:#E0E0E0; text-align:center; border-bottom:1px solid #707070;"][color=#ffa07a]2,556.6[/color][/td]
                                        [/tr]
                                        [tr style="background: linear-gradient(to top, #b08d57, #806a38); box-shadow: inset 0 -3px 6px rgba(0, 0, 0, 0.6);"]
                                            [th colspan="7" style="text-align:center; font-size:18px; text-transform:uppercase; font-weight:bold; color:#332b05; text-shadow:0 0 1px #806a35, 0px 0px 2px #b7974d;"]Enmity Generation (10 Mobs)[/th]
                                        [/tr]
                                        [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                            [th style="color:#ffd700; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Spell[/th]
                                            [th style="color:#ffd700; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]HP Healed[/th]
                                            [th style="color:#ffd700; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]Base CE((HP × 0.231) ÷ 10)[/th]
                                            [th style="color:#ffd700; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"]CE((+57/+30 Enmity) ÷ 10)[/th]
                                            [th style="color:#ffd700; text-align:center; border-bottom:1px solid #707070;"]Final VE((CE × 6) ÷ 10)[/th]
                                        [/tr]
                                        [tr style="background-color:rgba(26, 26, 26, 0.5);"]
                                            [td style="color:#E0E0E0; text-align:center; border-bottom:1px solid #707070; border-right:1px solid #707070;"][color=#00ffd0]Cure IV[/color][/td]
